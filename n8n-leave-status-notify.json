{
  "name": "Leave Status Notification (Requester)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "leave-status",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-leave-status",
      "name": "Webhook (Leave Status)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        180,
        240
      ],
      "webhookId": "leave-status-webhook-id"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.body.user.email }}",
        "subject": "=[แจ้งเตือน] คำขอลาของคุณได้รับการอัปเดตสถานะเป็น: {{ $json.body.status === 'confirmed' ? 'ยืนยันแล้ว' : ($json.body.status === 'approved' ? 'อนุมัติแล้ว' : 'ถูกปฏิเสธ') }}",
        "emailFormat": "html",
        "html": "=<div style=\"font-family: sans-serif; max-width: 600px; margin: 0 auto;\">\n  <div style=\"background: {{ $json.body.status === 'rejected' ? 'linear-gradient(135deg, #ff6b6b, #ee5a5a)' : 'linear-gradient(135deg, #11998e, #38ef7d)' }}; padding: 20px; border-radius: 10px 10px 0 0;\">\n    <h2 style=\"color: white; margin: 0;\">\n      {{ $json.body.status === 'confirmed' ? '✅ ใบลาถูกยืนยันเข้าระบบแล้ว' : ($json.body.status === 'approved' ? '✅ อนุมัติแล้ว' : '❌ ไม่อนุมัติ') }}\n    </h2>\n  </div>\n  <div style=\"background: white; padding: 20px; border: 1px solid #e2e8f0;\">\n    <p>คำขอลาของคุณได้รับการอัปเดตสถานะแล้ว (ผ่าน N8N)</p>\n    <p><strong>ประเภทการลา:</strong> {{ $json.body.leaveType.name }}</p>\n    <p><strong>จำนวนวัน:</strong> {{ $json.body.leaveRequest.totalDays }} วัน</p>\n    {{ $json.body.note ? `<p><strong>หมายเหตุ:</strong> ${$json.body.note}</p>` : '' }}\n    <div style=\"margin-top: 20px;\">\n      <a href=\"{{ $json.body.frontendUrl }}/leave-history\" style=\"background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;\">ดูประวัติการลา</a>\n    </div>\n  </div>\n</div>"
      },
      "id": "send-email-requester",
      "name": "Send Email to Requester",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        400,
        240
      ]
    }
  ],
  "connections": {
    "Webhook (Leave Status)": {
      "main": [
        [
          {
            "node": "Send Email to Requester",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
