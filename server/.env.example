# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (Generate a strong string e.g. using `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`)
JWT_SECRET=your_jwt_secret_here

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=leave_management
DB_USER=root
DB_PASSWORD=

# File Upload
UPLOAD_DIR=uploads

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=https://your-production-url.vercel.app

# Brevo (Sendinblue) - Email API
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# N8N Webhook API Key
N8N_API_KEY=your_n8n_api_key_here

# Cloudinary (Optional if using local storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
