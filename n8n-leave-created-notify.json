{
  "name": "Leave Created Notification (Admin)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "leave-created",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-leave-created",
      "name": "Webhook (New Leave)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        180,
        240
      ],
      "webhookId": "leave-created-webhook-id"
    },
    {
      "parameters": {
        "sendTo": "leavemanagementbru@gmail.com",
        "subject": "=[คำขอลาใหม่] {{ $json.body.user.firstName }} {{ $json.body.user.lastName }} - {{ $json.body.leaveType.name }}",
        "emailFormat": "html",
        "html": "=<div style=\"font-family: sans-serif; max-width: 600px; margin: 0 auto;\">\n  <div style=\"background: linear-gradient(135deg, #667eea, #764ba2); padding: 20px; border-radius: 10px 10px 0 0;\">\n    <h2 style=\"color: white; margin: 0;\">📝 คำขอลาใหม่ (ผ่าน N8N)</h2>\n  </div>\n  <div style=\"background: white; padding: 20px; border: 1px solid #e2e8f0;\">\n    <p><strong>พนักงาน:</strong> {{ $json.body.user.firstName }} {{ $json.body.user.lastName }}</p>\n    <p><strong>แผนก:</strong> {{ $json.body.user.department }}</p>\n    <p><strong>ประเภทการลา:</strong> {{ $json.body.leaveType.name }}</p>\n    <p><strong>จำนวนวัน:</strong> {{ $json.body.leaveRequest.totalDays }} วัน</p>\n    <p><strong>เหตุผล:</strong> {{ $json.body.leaveRequest.reason }}</p>\n    <div style=\"margin-top: 20px;\">\n      <a href=\"{{ $json.body.frontendUrl }}/approvals\" style=\"background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;\">ดูรายละเอียดและอนุมัติ</a>\n    </div>\n  </div>\n</div>"
      },
      "id": "send-email-admin",
      "name": "Send Email to Admin",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        400,
        240
      ]
    }
  ],
  "connections": {
    "Webhook (New Leave)": {
      "main": [
        [
          {
            "node": "Send Email to Admin",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}